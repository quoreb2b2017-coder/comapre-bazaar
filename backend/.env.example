# Server
PORT=5000
NODE_ENV=development
TRUST_PROXY=false
# Set to true behind reverse proxy / CDN (Cloudflare, Vercel, Nginx)
# so req.ip and forwarded headers resolve real visitor IP.
# TRUST_PROXY=true

# Database
# Atlas / hosted Mongo URI with database name in the path.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/appdb?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
ADMIN_EMAIL=admin@example.com
OTP_EXPIRY_MINUTES=10
OTP_LOG_IN_TERMINAL=true

# Frontend / CORS (required when blog-admin calls this API directly from the browser)
FRONTEND_URL=http://localhost:3000
FRONTEND_APP_URL=
# Production example:
# FRONTEND_URL=https://www.compare-bazaar.com
# CORS_ORIGINS=https://www.compare-bazaar.com,https://compare-bazaar.com
# compare-bazaar.com origins are also allowed by default in app.js
CORS_ORIGINS=

# Public backend URL (for webhook/external callbacks)
BACKEND_PUBLIC_URL=https://your-backend.up.railway.app
PUBLIC_API_URL=https://your-backend.up.railway.app
BLOG_ADMIN_BASE_PATH=/blog-admin

# Website publishing
WEBSITE_URL=https://your-website.com
WEBSITE_API_KEY=your-website-api-key
BLOG_VOICE_SITE_URL=

# Unsplash — topic-based cover images when generating blogs (free tier ~50 req/hr).
# Create an app at https://unsplash.com/oauth/applications — use "Access Key".
UNSPLASH_ACCESS_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TRENDS_MODEL=
BLOG_GENERATE_FAST=false
BLOG_GENERATE_MAX_TOKENS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Blog Admin <onboarding@resend.dev>
EMAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Analytics 4 (Super Admin dashboard sync via Data API)
# Property ID: GA4 Admin → Property settings → Property ID (numeric, not G- measurement ID)
# GA4_PROPERTY_ID=123456789
# GA4_MEASUREMENT_ID=G-H0RLG3LV41
# Service account JSON (single line) with Analytics Viewer on the GA4 property:
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Or file path:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json