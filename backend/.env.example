# Server
PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# Database
# Atlas / hosted Mongo URI with database name in the path.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/appdb?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
ADMIN_EMAIL=admin@example.com
OTP_EXPIRY_MINUTES=10

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
FRONTEND_APP_URL=
CORS_ORIGINS=

# Public backend URL (for webhook/external callbacks)
BACKEND_PUBLIC_URL=https://your-backend.up.railway.app
PUBLIC_API_URL=https://your-backend.up.railway.app
BLOG_ADMIN_BASE_PATH=/blog-admin

# Website publishing
WEBSITE_URL=https://your-website.com
WEBSITE_API_KEY=your-website-api-key
BLOG_VOICE_SITE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TRENDS_MODEL=
BLOG_GENERATE_FAST=false
BLOG_GENERATE_MAX_TOKENS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Blog Admin <onboarding@resend.dev>
EMAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=