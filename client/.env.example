# Backend used by Next rewrites and blog CMS fetch (Express API).
BACKEND_URL=awake-reflection-production-f61c.up.railway.app

# Optional: disable first-party page-view beacons from the marketing site (consent UI still shows).
# NEXT_PUBLIC_SITE_ANALYTICS=0

# Optional: full origin + path prefix to blog-admin API if the browser cannot use same-origin rewrites, e.g.
# NEXT_PUBLIC_SITE_ANALYTICS_URL=https://api.example.com/api/v1/blog-admin

# Marketing consent adds UTM + first-touch cookie cb_attr (~90d); analytics-only sends locale/device/viewport + edge country.

# Optional: where blog-admin sends users after logout (defaults to same origin `/`).
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://www.compare-bazaar.com

# Optional: Unsplash API — dynamic cover images from topic/tags/title (free tier: ~50 req/hr).
# Create an app at https://unsplash.com/oauth/applications — use “Access Key”.
# If unset, blog listings use built‑in topic → stock photo maps (no API calls).
UNSPLASH_ACCESS_KEY=
