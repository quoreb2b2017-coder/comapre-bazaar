# ─── Local development ─────────────────────────────────────────────────────────
# Run backend first: cd backend && npm run dev  (default http://127.0.0.1:5000)
# Then Next client: cd client && npm run dev
BACKEND_URL=http://127.0.0.1:5000

# ─── Production (Vercel / hosted Next) ───────────────────────────────────────
# Set on Vercel (server + rewrites). Use your PUBLIC Railway/API URL with https://
# BACKEND_URL=https://your-app.up.railway.app
#
# REQUIRED for blog-admin uploads (PDF up to 25 MB) — browser must call the API directly.
# Vercel rewrites cap proxied request bodies (~4.5 MB); without this, whitepaper publish returns 500.
# NEXT_PUBLIC_BACKEND_URL=https://your-app.up.railway.app
#
# Optional override (full path): NEXT_PUBLIC_BLOG_ADMIN_API_BASE=https://your-app.up.railway.app/api/v1/blog-admin
#
# On the backend host, also set:
# FRONTEND_URL=https://www.compare-bazaar.com
# CORS_ORIGINS=https://www.compare-bazaar.com,https://compare-bazaar.com
# CLOUDINARY_CLOUD_NAME=... CLOUDINARY_API_KEY=... CLOUDINARY_API_SECRET=...

# Optional: server-side CMS fetch override (same value as BACKEND_URL is fine)
# BLOG_CMS_BACKEND_URL=http://127.0.0.1:5000

# Optional: disable first-party page-view beacons from the marketing site (consent UI still shows).
# NEXT_PUBLIC_SITE_ANALYTICS=0

# Optional: full origin + path prefix to blog-admin API if the browser cannot use same-origin rewrites, e.g.
# NEXT_PUBLIC_SITE_ANALYTICS_URL=https://api.example.com/api/v1/blog-admin

# Marketing consent adds UTM + first-touch cookie cb_attr (~90d); analytics-only sends locale/device/viewport + edge country.

# Optional: where blog-admin sends users after logout (defaults to same origin `/`).
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://www.compare-bazaar.com

# Optional: Unsplash API — dynamic cover images from topic/tags/title (free tier: ~50 req/hr).
# Create an app at https://unsplash.com/oauth/applications — use “Access Key”.
# If unset, blog listings use built‑in topic → stock photo maps (no API calls).
UNSPLASH_ACCESS_KEY=
